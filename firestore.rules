rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /properties/{propertyId} {
      allow read, write: if true;
    }
    match /testimonials/{testimonialId} {
      allow read, write: if true;
    }
    match /leads/{leadId} {
      allow read, write, create: if true;
    }
    match /site_settings/{document=**} {
      allow read, write: if true;
    }
  }
}
